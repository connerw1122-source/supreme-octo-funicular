// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  pin       String   // Simple PIN-based login for demo
  createdAt DateTime @default(now())
  sessions  Session[]
}

model Session {
  id          String   @id @default(cuid())
  code        String   @unique // 6-character code customers enter
  title       String   // Friendly description, e.g. "Help with printer"
  customerName String?
  status      String   @default("waiting") // waiting | active | ended
  technicianId String?
  technician  Technician? @relation(fields: [technicianId], references: [id])
  // For unattended sessions: link to the registered machine
  unattendedMachineId String?
  unattendedMachine   UnattendedMachine? @relation(fields: [unattendedMachineId], references: [id])
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  endedAt     DateTime?
  messages    ChatMessage[]
  events      SessionEvent[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String   // "technician" | "customer" | "system"
  content   String
  createdAt DateTime @default(now())
}

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String   // "created" | "joined" | "started" | "ended" | "file_sent" | ...
  detail    String?
  createdAt DateTime @default(now())
}

// A customer machine that has been set up for unattended access.
// The technician can start a session to it at any time without the customer
// needing to be present or enter a code.
model UnattendedMachine {
  id            String   @id @default(cuid())
  machineCode   String   @unique // 6-digit numeric code the installer registers with
  customerName  String   // Friendly label, e.g. "Front desk PC"
  hostname      String?
  os            String?
  status        String   @default("offline") // online | offline
  lastSeenAt    DateTime?
  installedAt   DateTime @default(now())
  sessions      Session[]
  activityLogs  ActivityLog[]
  appUsages     AppUsage[]
  websiteVisits WebsiteVisit[]
  screenshots   Screenshot[]
  productivityScores ProductivityScore[]
}

// Activity log entries — one per heartbeat interval (e.g. every 30s).
// Records mouse clicks, keystrokes, and idle/active status for that interval.
model ActivityLog {
  id            String   @id @default(cuid())
  machineId     String
  machine       UnattendedMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  timestamp     DateTime @default(now())
  mouseClicks   Int      @default(0)
  keystrokes    Int      @default(0)
  mouseMoves    Int      @default(0)
  isActive      Boolean  @default(true) // false if idle (no input for >60s)
  activeAppName String?  // The foreground app during this interval
  activeAppTitle String? // The window title of the foreground app
}

// Application usage — tracks how long each app was in the foreground.
model AppUsage {
  id            String   @id @default(cuid())
  machineId     String
  machine       UnattendedMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  appName       String   // e.g. "excel.exe", "chrome.exe"
  windowTitle   String?  // e.g. "Budget.xlsx - Excel"
  category      String   @default("neutral") // productive | unproductive | neutral
  startTime     DateTime @default(now())
  duration      Int      @default(0) // seconds
  timestamp     DateTime @default(now())
}

// Website visits — tracks URLs visited in browsers.
model WebsiteVisit {
  id            String   @id @default(cuid())
  machineId     String
  machine       UnattendedMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  url           String   // The URL visited
  title         String?  // The page title
  browser       String?  // "chrome" | "edge" | "firefox"
  category      String   @default("neutral") // productive | unproductive | neutral
  startTime     DateTime @default(now())
  duration      Int      @default(0) // seconds spent on the page
  timestamp     DateTime @default(now())
}

// Periodic screenshots for audit trail.
model Screenshot {
  id            String   @id @default(cuid())
  machineId     String
  machine       UnattendedMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  timestamp     DateTime @default(now())
  // Image stored as base64 JPEG (small thumbnail quality)
  imageData     String
  width         Int
  height        Int
}

// Daily productivity score per machine.
model ProductivityScore {
  id            String   @id @default(cuid())
  machineId     String
  machine       UnattendedMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  date          DateTime @default(now())
  score         Int      @default(0) // 0-100
  activeTime    Int      @default(0) // seconds active
  idleTime      Int      @default(0) // seconds idle
  totalTime     Int      @default(0) // total tracked time
  topApps       String?  // JSON string of top apps with durations
  topSites      String?  // JSON string of top sites with durations
}

// Global monitoring configuration — admin-configurable settings.
model MonitoringConfig {
  id                    String   @id @default("singleton")
  // Interval settings (in seconds)
  activityInterval      Int      @default(30)    // How often to report activity
  screenshotInterval    Int      @default(300)   // How often to capture screenshots (5 min)
  idleThreshold         Int      @default(60)    // Seconds without input = idle
  // Screenshot settings
  screenshotQuality     Int      @default(40)    // JPEG quality (1-100)
  screenshotWidth       Int      @default(320)   // Thumbnail width
  screenshotHeight      Int      @default(180)   // Thumbnail height
  maxScreenshots        Int      @default(100)   // Max screenshots to keep per machine
  // Features toggles
  trackMouseClicks      Boolean  @default(true)
  trackKeystrokes       Boolean  @default(true)
  trackAppUsage         Boolean  @default(true)
  trackWebsites         Boolean  @default(true)
  captureScreenshots    Boolean  @default(true)
  trackMouseMoves       Boolean  @default(false) // Off by default (high volume)
  // App/website categorization (JSON arrays of patterns)
  productiveApps        String   @default("[]")  // JSON: ["excel", "word", ...]
  unproductiveApps      String   @default("[]")  // JSON: ["solitaire", "steam", ...]
  productiveWebsites    String   @default("[]")  // JSON: ["github.com", ...]
  unproductiveWebsites  String   @default("[]")  // JSON: ["facebook.com", ...]
  // Data retention (days)
  retentionDays         Int      @default(30)    // Auto-delete data older than this
  updatedAt             DateTime @default(now())
}
