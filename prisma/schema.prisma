// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  pin       String   // Simple PIN-based login for demo
  createdAt DateTime @default(now())
  sessions  Session[]
}

model Session {
  id          String   @id @default(cuid())
  code        String   @unique // 6-character code customers enter
  title       String   // Friendly description, e.g. "Help with printer"
  customerName String?
  status      String   @default("waiting") // waiting | active | ended
  technicianId String?
  technician  Technician? @relation(fields: [technicianId], references: [id])
  // For unattended sessions: link to the registered machine
  unattendedMachineId String?
  unattendedMachine   UnattendedMachine? @relation(fields: [unattendedMachineId], references: [id])
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  endedAt     DateTime?
  messages    ChatMessage[]
  events      SessionEvent[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    String   // "technician" | "customer" | "system"
  content   String
  createdAt DateTime @default(now())
}

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      String   // "created" | "joined" | "started" | "ended" | "file_sent" | ...
  detail    String?
  createdAt DateTime @default(now())
}

// A customer machine that has been set up for unattended access.
// The technician can start a session to it at any time without the customer
// needing to be present or enter a code.
model UnattendedMachine {
  id            String   @id @default(cuid())
  machineCode   String   @unique // 6-digit numeric code the installer registers with
  customerName  String   // Friendly label, e.g. "Front desk PC"
  hostname      String?
  os            String?
  status        String   @default("offline") // online | offline
  lastSeenAt    DateTime?
  installedAt   DateTime @default(now())
  sessions      Session[]
}
